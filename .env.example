# ─────────────────────────────────────────────────────────────
# SchoolCo Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App URL (required for auth callbacks) ─────────────────────
# Development:  http://localhost:3000
# Staging:      https://staging.schoolco.app
# Production:   https://schoolco.app  (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Default Organization ──────────────────────────────────────
# The slug of the first / primary organization on this instance.
# Used for default redirects and onboarding. NOT hard-coded.
NEXT_PUBLIC_DEFAULT_ORGANIZATION_SLUG=rising-leaders-academy

# ── Supabase Service Role Key ─────────────────────────────────
# IMPORTANT: This key bypasses all RLS policies.
# - NEVER prefix with NEXT_PUBLIC_
# - NEVER import into client components or browser-side code
# - ONLY use in Server Actions, Route Handlers, or server utilities
# - Treat it like a database root password
# Found in: Supabase Dashboard → Project Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (Sprint 2 — do not add until Sprint 2 begins) ──────
# Transactional email provider for guardian notifications,
# announcements, and incident alerts.
# - NEVER prefix with NEXT_PUBLIC_
# - ONLY use in Server Actions or Route Handlers
# Found in: resend.com → API Keys → Create API Key
# See: RESEND_SETUP.md for full setup instructions
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
